# N8N Configuration
N8N_HOST=your-domain-or-ip
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-domain-or-ip/

# Admin Credentials (CHANGE THESE!)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=YourStrongPasswordHere

# Encryption Key (generate a random 32-char string)
N8N_ENCRYPTION_KEY=change-this-to-a-random-32char-key

# Database Password
DB_PASSWORD=YourDBPasswordHere

# WhatsApp Business API (Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# Your WhatsApp number (for receiving alerts)
MY_WHATSAPP_NUMBER=923396267447
